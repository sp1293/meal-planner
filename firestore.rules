rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users: only the owner can read/write their own doc ─────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow updates but block sensitive fields (backend handles those via Admin SDK)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["tier", "paymentId", "orderId", "subscribedAt",
                     "subscribedVia", "role", "referredBy", "referrals",
                     "plansUsed"]);
      allow delete: if false;
    }

    // ── Trainers: signed-in users can read, no client writes ───────────
    match /trainers/{trainerId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── Bookings: students read their own, no client writes ────────────
    match /bookings/{bookingId} {
      allow read: if request.auth != null
        && resource.data.studentId == request.auth.uid;
      allow write: if false;
    }

    // ── Waitlist: open creation only ───────────────────────────────────
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Webhook events: backend-only ───────────────────────────────────
    match /webhookEvents/{eventId} {
      allow read, write: if false;
    }

    // ── Default deny ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}